# ─── Required ────────────────────────────────────────────────────────
# Server-side Google Maps key. Needs: Geocoding, Places, Maps Static,
# Street View Static APIs (and Maps JavaScript if you keep 360.html).
GOOGLE_MAPS_API_KEY=your_server_side_key_here

# ─── Optional ────────────────────────────────────────────────────────
# Browser-side key embedded in the generated 360.html. Use a separate,
# HTTP-referrer-restricted key so the server key never lands in files the
# client pushes to storage. Falls back to GOOGLE_MAPS_API_KEY if blank.
GOOGLE_MAPS_BROWSER_KEY=

# Prefix for the returned ZIP filename -> {prefix}_{timestamp}_{id}.zip
ZIP_NAME_PREFIX=proposition

# Host port to expose the service on (container always listens on 8000).
HOST_PORT=8000

# Gunicorn tuning.
WORKERS=4
TIMEOUT=120
